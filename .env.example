# ── LLM Provider ───────────────────────────────────────────────────────────
# 選擇: "ollama" (本地), "gemini" (免費API), "groq" (免費API)
LLM_PROVIDER=ollama

# ── Ollama (本地，不需要 API Key) ───────────────────────────────────────────
# 推薦模型（中文支援佳）：qwen2:7b, qwen2.5:7b, qwen2:1.5b（輕量）
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2:7b

# ── Google Gemini（免費，15次/分鐘）──────────────────────────────────────────
# 申請金鑰：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Groq（免費，有速率限制）────────────────────────────────────────────────
# 申請金鑰：https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
