# ── LLM Provider ───────────────────────────────────────────────────────────
# 選擇: "ollama" (本地), "gemini" (免費API), "groq" (免費API)
LLM_PROVIDER=ollama

# ── Ollama (本地，不需要 API Key) ───────────────────────────────────────────
# 記憶體需求對照（需要 Docker Desktop 分配足夠 RAM）：
#   qwen2:1.5b  → ~1 GiB  (預設，適合 Docker 記憶體 < 6 GiB)
#   qwen2:7b    → ~4.1 GiB (需要 Docker 記憶體 ≥ 6 GiB)
#   qwen2.5:3b  → ~2 GiB  (品質與大小的平衡)
OLLAMA_HOST=http://localhost:11434
# (Docker 內部請改用 http://host.docker.internal:11434)
OLLAMA_MODEL=qwen2:1.5b

# ── Google Gemini（免費，15次/分鐘）──────────────────────────────────────────
# 申請金鑰：https://aistudio.google.com/app/apikey
# 多個金鑰用逗號分隔，額度耗盡時自動輪換
GEMINI_API_KEYS=key1,key2,key3

# 付費備用金鑰：所有免費金鑰額度耗盡時自動啟用，並記錄花費
# 留空則不啟用付費備援
PAID_GEMINI_API_KEY=
# 是否啟用付費備援（true/false，預設 true）
PAID_GEMINI_ENABLED=true

# ── Groq（免費，有速率限制）────────────────────────────────────────────────
# 申請金鑰：https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
